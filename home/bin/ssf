#!/usr/bin/env bash
set -euo pipefail

linux_select_proc() {
  select_line="$(sudo ss -plnt | fzf --prompt="process> " \
    --height=~50% \
    --reverse \
    -q "'$1" \
    --header-lines="1")"
  if [[ -z "$select_line" ]]; then
    exit
  else
    echo "$select_line" | sed -n 's/.*pid=\([0-9]\+\).*/\1/p'
  fi
}

darwin_select_proc() {
  select_line="$(sudo lsof -iTCP -sTCP:LISTEN -P | fzf --prompt="process> " \
    --height=~50% \
    --reverse \
    -q "'$1" \
    --header-lines="1")"
  if [[ -z "$select_line" ]]; then
    exit
  else
    echo "$select_line" | awk '{print $2}'
  fi
}

select_proc() {
  if [[ "$(uname)" == "Linux" ]]; then
    linux_select_proc "${1:-}"
  elif [[ "$(uname)" == "Darwin" ]]; then
    darwin_select_proc "${1:-}"
  fi
}

show_tree() {
  pid="$1"

  echo
  pstree -w -g 3 -p "$pid" | grep -C 1000000 "$pid" --color=always
  echo
}

PID="$(select_proc "${1:-}")"

if [[ -z "$PID" ]]; then
  exit
fi

ps -p "$PID" -f

while true; do
  ACTION=$(echo -e "tree\nkill" | fzf --prompt="Action for $PID> " --height=~20% --reverse)

  if [[ -z "$ACTION" ]]; then
    break
  fi

  case "$ACTION" in
  tree)
    show_tree "$PID"
    ;;
  kill)
    kill -9 "$PID"
    echo -e "${YELLOW}Stopped $PID${NC}"
    exit
    ;;
  *)
    break
    ;;
  esac
done

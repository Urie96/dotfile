#!/usr/bin/env bash
set -euo pipefail

# launchz - Interactive launchd service manager using fzf

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Ensure fzf is installed
if ! command -v fzf >/dev/null 2>&1; then
  echo -e "${RED}fzf not found. Install with: brew install fzf${NC}"
  exit 1
fi

# Get service list
get_services() {
  launchctl list | awk 'NR>1 {print $3}' | sort
}

# Show service details
show_details() {
  local service="$1"
  echo -e "${GREEN}Service: $service${NC}"
  echo
  if [[ "$(id -u)" == "0" ]]; then
    launchctl print "system/$service"
  else
    launchctl print "gui/$(id -u)/$service"
  fi | bat -l nix --plain --paging=always
}

SERVICE=$(get_services | fzf --prompt="launchd service> " --height=~50% --reverse --preview="launchctl list | grep -E '^\S+\s+\S+\s+{}$'")

[[ -z "$SERVICE" ]] && exit

while true; do
  ACTION=$(echo -e "details\nstart\nstop\nrestart\nlogs" | fzf --prompt="Action for $SERVICE> " --height=~20% --reverse)
  case "$ACTION" in
  details)
    show_details "$SERVICE"
    ;;
  start)
    launchctl start "$SERVICE"
    echo -e "${GREEN}Started $SERVICE${NC}"
    sleep 1
    ;;
  stop)
    launchctl stop "$SERVICE"
    echo -e "${YELLOW}Stopped $SERVICE${NC}"
    sleep 1
    ;;
  restart)
    launchctl stop "$SERVICE"
    launchctl start "$SERVICE"
    echo -e "${GREEN}Restarted $SERVICE${NC}"
    sleep 1
    ;;
  logs)
    echo -e "${YELLOW}Recent logs for $SERVICE (via log show)...${NC}"
    log show --predicate "process == '$SERVICE'" --last 1h --style compact
    read -rp "Press Enter to continue..."
    ;;
  *)
    exit
    ;;
  esac
done

#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/bin:/etc/profiles/per-user/$USER/bin/:$PATH"

press_any_key() {
  if [[ -r /dev/tty ]]; then
    printf 'Press any key to exit...' >&2
    IFS= read -r -n 1 _ </dev/tty || true
    printf '\n' >&2
  fi
}

die() {
  printf 'tmux-sesh: %s\n' "$*" >&2
  press_any_key
  exit 1
}

tmux_sesh_preview() {
  case "$1" in
  p)
    IFS='|' read -r wid pid <<< "$2"
    tmux capture-pane -t "$wid" -p -e -S -60 2>/dev/null || echo "(unavailable)"
    ;;
  d)
    printf '%s\n\n' "$2"
    ls --color=always "$2" | head -70
    ;;
  esac
}

tmux_sesh_items() {
  [[ -n "${TMUX:-}" ]] || die 'run inside a tmux session'

  # format: win_active|pane_active|window_id|pane_id|title|cwd|window_name
  # skip only the globally focused pane (win_active=1 AND pane_active=1)
  # target = win_id.pane_index (e.g. @0.2) so tmux can find the pane across windows
  tmux list-panes -a -F '#{?window_active,1,0}|#{?pane_active,1,0}|#{window_id}|#{pane_id}|#{pane_title}|#{pane_current_path}|#{window_name}' 2>/dev/null |
    while IFS='|' read -r wactive pactive win_id pid title cwd win; do
      [[ "$wactive" == 1 && "$pactive" == 1 ]] && continue  # skip globally focused pane
      [[ -z "$title" ]] && title="$win"
      target="${win_id}|${pid}"
      printf 'p\t%s\t\033[38;5;75m󰖲 \033[0m\033[38;5;214m%s\033[0m  \033[38;5;245m%s\033[0m\n' "$target" "$title" "$cwd"
    done

  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    display_dir="$dir"
    case "$display_dir" in
    "$HOME") display_dir='~' ;;
    "$HOME"/*) display_dir="~/${display_dir#"$HOME"/}" ;;
    esac
    printf 'd\t%s\t\033[38;5;114m󰉋 \033[0m%s\n' "$dir" "$display_dir"
  done < <(zoxide query --list)
}

tmux_sesh_delete() {
  [[ $# -ge 2 ]] || return 0

  case "$1" in
  p)
    IFS='|' read -r wid pid <<< "$2"
    tmux select-window -t "$wid" \; kill-pane -t "$pid" 2>/dev/null || true
    ;;
  d)
    zoxide remove "$2"
    ;;
  esac
}

export -f press_any_key die tmux_sesh_preview tmux_sesh_items tmux_sesh_delete

bash_path="${BASH:-}"
if [[ -z "$bash_path" ]]; then
  bash_path="$(command -v bash)" || die 'failed to find bash'
fi

SHELL="$bash_path" selection="$(tmux_sesh_items | fzf \
  --prompt='tmux> ' \
  --header='enter: switch/open  ctrl-e: open dir in nvim  ctrl-d: close/remove' \
  --preview-window=border-left \
  --ansi \
  --delimiter=$'\t' \
  --with-nth=3 \
  --nth=1 \
  --no-sort \
  --exact \
  --expect=ctrl-e \
  --bind 'ctrl-d:execute-silent(bash -c "tmux_sesh_delete {1} {2}")+reload(tmux_sesh_items)' \
  --preview-window='right:70%,nowrap' \
  --preview 'tmux_sesh_preview {1} {2}')" || exit 0

key="${selection%%$'\n'*}"
selected="${selection#*$'\n'}"
[[ -n "$selected" && "$selected" != "$selection" ]] || exit 0

IFS=$'\t' read -r kind target _display <<<"$selected"

case "$kind:$key" in
p:*)
  IFS='|' read -r wid pid <<< "$target"
  tmux select-window -t "$wid" \; select-pane -t "$pid"
  ;;
d:ctrl-e)
  window_id="$(tmux new-window -P -a -c "$target" -n "nvim" 2>/dev/null)"
  tmux send-keys -t "$window_id" 'nvim' Enter
  ;;
d:*)
  tmux new-window -a -c "$target" >/dev/null
  ;;
*)
  die "unknown selection type: $kind"
  ;;
esac

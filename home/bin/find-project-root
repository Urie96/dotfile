#!/usr/bin/env python3
"""Find the project root directory by searching for common project markers."""

import os
import sys
from pathlib import Path


def main():
    # Get start path from command line or use current directory
    if len(sys.argv) > 1:
        start_path = Path(sys.argv[1])
    else:
        start_path = Path(os.environ.get("PWD", "."))
    
    # Make path absolute if it's not already
    if not start_path.is_absolute():
        pwd = os.environ.get("PWD", ".")
        start_path = Path(pwd) / start_path
    
    # If it's a file, use its parent directory
    if start_path.is_file():
        start_path = start_path.parent
    
    # Project root markers to search for
    roots = [
        ".git",
        "Cargo.toml",
        "go.mod",
        "package.json",
        "Pipfile",
        "setup.py",
        "pyproject.toml",
        "poetry.lock",
        ".lazy.lua",
        "pom.xml",
    ]
    
    # Search upward for project root
    dir_path = start_path
    while True:
        if any((dir_path / marker).exists() for marker in roots):
            print(dir_path)
            return
        
        parent = dir_path.parent
        if parent == dir_path:  # Reached filesystem root
            return
        
        dir_path = parent


if __name__ == "__main__":
    main()

#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${ANDROID_SERIAL:-}" ]]; then
  ANDROID_SERIAL="$(command adb devices -l | grep -E '\sdevice\s' | fzf --bind one:accept --exit-0 | awk '{print $1}')"
  export ANDROID_SERIAL
fi

select_pkg() {
  local user_pkgs sys_pkgs
  user_pkgs="$(adb shell pm list packages -3 | sed 's/package://' | sort | awk '{print "\033[32m[User]   \033[0m" $0}')"
  sys_pkgs="$(adb shell pm list packages -s | sed 's/package://' | sort | awk '{print "\033[33m[System] \033[0m" $0}')"
  printf "%b\n%b" "$user_pkgs" "$sys_pkgs" | fzf \
    --ansi \
    --no-sort \
    --height 80% \
    --layout=reverse \
    --border \
    --prompt="Select App > "
}

operate_pkg() {
  local pkg="$1"
  local actions=(
    "🚀 Launch App (Start)"
    "ℹ️ App Info (Settings)"
    "🛑 Force Stop"
    "📥 Pull APK (Export)"
    "🧹 Clear Data"
    "🗑️ Uninstall"
  )
  local select_action
  select_action=$(printf "%s\n" "${actions[@]}" | fzf \
    --height 40% \
    --layout=reverse \
    --border \
    --prompt="Action for $pkg > " \
    --header="Select an action to perform")

  case "$select_action" in
  *"Launch App"*)
    echo "正在尝试启动 $pkg ..."
    # 使用 monkey 是一种通用的启动方式，不需要知道具体的 Main Activity
    adb shell monkey -p "$pkg" -c android.intent.category.LAUNCHER 1 >/dev/null 2>&1
    echo "已发送启动指令。"
    ;;
  *"Force Stop"*)
    adb shell am force-stop "$pkg"
    echo "已强制停止 $pkg"
    ;;
  *"Pull APK"*)
    # 1. 获取 APK 路径
    PATH_LINE=$(adb shell pm path "$pkg")
    # 格式通常是 package:/data/app/xxx/base.apk，需要去掉前缀
    REMOTE_PATH=${PATH_LINE#package:}

    if [ -z "$REMOTE_PATH" ]; then
      echo "无法找到 APK 路径，可能应用是系统应用或无权限访问。"
    else
      echo "正在导出 APK 从: $REMOTE_PATH"
      adb pull "$REMOTE_PATH" "./${pkg}.apk"
      echo "导出完成: ./${pkg}.apk"
    fi
    ;;
  *"App Info"*)
    echo "打开应用详情页..."
    adb shell am start -a android.settings.APPLICATION_DETAILS_SETTINGS -d "package:$pkg" >/dev/null
    ;;
  *"Clear Data"*)
    echo "正在清除数据..."
    adb shell pm clear "$pkg"
    echo "数据已清除。"
    ;;
  *"Uninstall"*)
    echo "正在卸载 $pkg ..."
    adb uninstall "$pkg"
    ;;
  esac
}

pkg=$(select_pkg | awk '{print $2}')
adb shell dumpsys package "$pkg" | grep -E "versionName|versionCode|userId|firstInstallTime|lastUpdateTime|dataDir|codePath|installerPackageName" | sed "s/^[ \t]*//"
operate_pkg "$pkg"

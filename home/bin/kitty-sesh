#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/bin:/run/current-system/sw/bin:$PATH"

press_any_key() {
  if [[ -r /dev/tty ]]; then
    printf 'Press any key to exit...' >&2
    IFS= read -r -n 1 _ </dev/tty || true
    printf '\n' >&2
  fi
}

die() {
  printf 'kitty-sesh: %s\n' "$*" >&2
  press_any_key
  exit 1
}

kitty_sesh_preview() {
  case "$1" in
  w)
    kitten @ get-text --match "id:$2" --extent screen --ansi
    ;;
  d)
    printf '%s\n\n' "$2"
    ls --color=always "$2" | head -70
    ;;
  esac
}

kitty_sesh_items() {
  kitten @ ls --match 'not state:focused' |
    jq -r '
      .[].tabs[].windows[]
      | [
          "w",
          (.id | tostring),
          ("\u001b[38;5;75m󰖲 \u001b[0m" + (if (.title // "") == "" then "(untitled)" else .title end))
        ]
      | @tsv
    ' || die 'failed to list kitty windows; run inside kitty or configure remote control'

  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    display_dir="$dir"
    case "$display_dir" in
    "$HOME") display_dir='~' ;;
    "$HOME"/*) display_dir="~/${display_dir#"$HOME"/}" ;;
    esac
    printf 'd\t%s\t\033[38;5;114m󰉋 \033[0m%s\n' "$dir" "$display_dir"
  done < <(zoxide query --list)
}

kitty_sesh_delete() {
  [[ $# -ge 2 ]] || return 0

  case "$1" in
  w)
    kitten @ close-window --match "id:$2"
    ;;
  d)
    zoxide remove "$2"
    ;;
  esac
}

export -f press_any_key die kitty_sesh_preview kitty_sesh_items kitty_sesh_delete

bash_path="${BASH:-}"
if [[ -z "$bash_path" ]]; then
  bash_path="$(command -v bash)" || die 'failed to find bash'
fi

SHELL="$bash_path" selection="$(kitty_sesh_items | fzf \
  --prompt='kitty> ' \
  --header='enter: switch/open  ctrl-e: open dir in nvim  ctrl-d: close/remove' \
  --preview-window=border-left \
  --ansi \
  --delimiter=$'\t' \
  --with-nth=3 \
  --nth=1 \
  --no-sort \
  --exact \
  --expect=ctrl-e \
  --bind 'ctrl-d:execute-silent(kitty_sesh_delete {1} {2})+reload(kitty_sesh_items)' \
  --preview-window='right:70%,nowrap' \
  --preview 'kitty_sesh_preview {1} {2}')" || exit 0

key="${selection%%$'\n'*}"
selected="${selection#*$'\n'}"
[[ -n "$selected" && "$selected" != "$selection" ]] || exit 0

IFS=$'\t' read -r kind target _display <<<"$selected"

case "$kind:$key" in
w:*)
  kitten @ focus-window --match "id:$target"
  ;;
d:ctrl-e)
  window_id="$(kitten @ launch --type=tab --location=after --cwd "$target")"
  kitten @ send-text --match "id:$window_id" 'nvim\n'
  ;;
d:*)
  kitten @ launch --type=tab --location=after --cwd "$target" >/dev/null
  ;;
*)
  die "unknown selection type: $kind"
  ;;
esac

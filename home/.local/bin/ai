#!/usr/bin/env bash
set -euo pipefail

mkdir -p "$HOME/.config/aichat/sessions"
cd "$HOME/.config/aichat/sessions"

summary() {
  local chat_file="$1.yaml"
  if [[ ! -f "$chat_file" ]]; then
    exit 0
  fi

  local summary_prompt
  summary_prompt='* Role: Content Summarizer

* Action: Carefully read the provided dialogue content and extract a concise title that best represents the core theme and essence of the dialogue.

* Context: 
  - The title should be brief and convey the main content of the dialogue quickly.
  - It needs to capture the key information and core intention of the dialogue.
  - The title length should be controlled within 15-30 characters.
  - The language style must be clear and professional, avoiding colloquial expressions.

* Expectations:
  - Output a precise and concise title.
  - Ensure the title accurately reflects the essence of the dialogue.
  - Do not output anything else, just output the title directly, do not provide options.

Please provide your dialogue content:  

'"$(cat "$chat_file")"

  local summary_text
  summary_text="$(aichat --no-stream "$summary_prompt")"

  mv "$chat_file" "${summary_text}.yaml"
}

chat() {
  local session_name="$RANDOM"
  aichat -s $session_name --save-session "$@"
  # summary "$session_name" &
}

list() {
  export query_cmd="ls -t ./*.yaml | sed 's|^\./||; s|\.yaml$||'"

  eval "$query_cmd" | fzf \
    --preview='bat --color=always --no-pager --style=plain {}.yaml' \
    --preview-window=right:60%:wrap \
    --bind="ctrl-d:execute(rm {}.yaml)+reload($query_cmd)" |
    xargs -I{} aichat -s {} --save-session
}

main() {
  if [[ "${1:-}" == "-l" ]]; then
    list
    exit $?
  fi

  chat "$@"
}

main "$@"

#!/usr/bin/env -S nu -n --no-std-lib --no-history

def main [
  regex: string
] {
  let cands = (get_chrome_tabs | where url =~ $regex)
  if ($cands | length) == 0 {
    exit 1
  }
  $cands | first | do {
    print $"Try to active ($in.url)"
    active_chrome_tab $in.win_id $in.tab_index
  }
}

def get_chrome_tabs [] {
  '
set _output to ""
tell application "Google Chrome"
  repeat with w in windows
    set _w_id to get id of w as inches as string
    set _tab_index to 1
    repeat with t in tabs of w
      set _url to get URL of t
      set _output to (_output & _url & "~~~" & _w_id & "~~~" & _tab_index & "\n")
      set _tab_index to _tab_index + 1
    end repeat
  end repeat
end tell
return _output
  '
  | ^osascript 
  | lines | parse -r '^(?<url>.+)~~~(?<win_id>\d+)~~~(?<tab_index>\d+)$' 
  | each {{
      url: $in.url
      win_id: ($in.win_id | into int)
      tab_index: ($in.tab_index | into int)
    }}
}

def active_chrome_tab [
  win_id: int,
  tab_index: int,
] {
  $'
tell application "Google Chrome"
  activate
  set _wnd to first window where id is ($win_id)
  set index of _wnd to 1
  set active tab index of _wnd to ($tab_index)
end tell
  ' | ^osascript
}

{
  "class": {
    "body": "public class ${1:TM_FILENAME_BASE} {\n  $0\n}\n",
    "prefix": "class"
  },
  "dowhile": {
    "body": "do {\n  $0\n} while (${1:condition})\n",
    "prefix": "dowhile"
  },
  "foreach": {
    "body": "for (${1:type} ${2:var} : ${3:iterable}) {\n  $0\n}\n",
    "prefix": "foreach"
  },
  "fori": {
    "body": "for (int ${1:i} = 0; $1 < ${2:100}; $1++) {\n  $0\n}\n",
    "prefix": "fori"
  },
  "if": {
    "body": "if (${1:condition}) {\n  $0\n}\n",
    "prefix": "if"
  },
  "ifelse": {
    "body": "if (${1:condition}) {\n  $2\n} else {\n  $0\n}\n",
    "prefix": "ifelse"
  },
  "main": {
    "body": "public static void main(String[] args) {\n  $0\n}\n",
    "prefix": "main"
  },
  "newObject": {
    "body": "${1:Object} ${2:foo} = new ${1:Object}();\n",
    "prefix": "newObject"
  },
  "switch": {
    "body": "switch (${1:key}) {\n  case ${2:value}:\n    $0\n    break;\n\n  default:\n    break;\n}\n",
    "prefix": "switch"
  },
  "syserr": {
    "body": "System.err.println($0);\n",
    "prefix": "syserr"
  },
  "sysout": {
    "body": "System.out.println($0);",
    "prefix": [
      "sysout",
      "print"
    ]
  },
  "trycatch": {
    "body": "try {\n  $1\n} catch (${2:Exception} ${3:e}) {\n  $4\n}\n",
    "prefix": "trycatch"
  },
  "while": {
    "body": "while (${1:condition}) {\n  $0\n}\n",
    "prefix": "while"
  }
}

{
  "assettype": {
    "body": "if typing.TYPE_CHECKING:\n  assert isinstance($1, $2), \"$1 type should be $2\"\n",
    "prefix": "assettype"
  },
  "class": {
    "body": "class $1($2):\n    def __init__(self, $4):\n        super($1, self).__init__($4))\n        $0\n",
    "prefix": "class"
  },
  "elif": {
    "body": "elif $1:\n    $0\n",
    "prefix": "elif"
  },
  "else": {
    "body": "else:\n  ${0:pass}\n",
    "prefix": "else"
  },
  "env": {
    "body": "#!/usr/bin/env python",
    "prefix": "env"
  },
  "fori": {
    "body": "for $1 in range(1, len($2)):\n  print($1)\n",
    "prefix": "fori"
  },
  "forr": {
    "body": "for ${1:item} in ${2:list}:\n  ${0:pass}\n",
    "prefix": "forr"
  },
  "from": {
    "body": "from ${1} import ${2}",
    "prefix": "from"
  },
  "function": {
    "body": "def ${1:funcname}(${2:args}):\n  ${0:pass}\n",
    "prefix": [
      "def",
      "func"
    ]
  },
  "if": {
    "body": "if ${1:True}:\n  ${0:pass}\n",
    "prefix": "if"
  },
  "import": {
    "body": "import ${1}",
    "prefix": "import"
  },
  "magic": {
    "body": "__${1}__",
    "prefix": "magic"
  },
  "main": {
    "body": "if __name__ == '__main__':\n    ${1:main()}\n",
    "prefix": "main"
  },
  "method": {
    "body": "def $1(self${2:, args}):\n    $0\n",
    "prefix": "method"
  },
  "rematch": {
    "body": "match = re.search(r'^(\\d+)\\$}', \"\")\nprint(match.group(1))\n",
    "prefix": "rematch"
  },
  "stdin": {
    "body": "import fileinput\n\n[line[:-1] for line in fileinput.input()]\n",
    "prefix": "stdin"
  },
  "switch": {
    "body": "match value:\n  case 1:\n    pass\n  case 2:\n    pass\n  case _:\n    pass\n",
    "prefix": "switch"
  },
  "try": {
    "body": "try:\n    ${1:print(0)}\nexcept $2:\"\n    $3\"\n",
    "prefix": "try"
  },
  "while": {
    "body": "while $1:\n    pass\n",
    "prefix": "while"
  }
}

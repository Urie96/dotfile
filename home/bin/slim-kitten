#!/usr/bin/env python

import json
import os
import re
import socket
import sys


def encode_send(send: dict) -> bytes:
    es = ('@kitty-cmd' + json.dumps(send)).encode('ascii')
    return b'\x1bP' + es + b'\x1b\\'


def write_tty(data: bytes):
    with open('/dev/tty', 'wb') as tty:
        tty.write(data)
        tty.flush()


def get_socket_address() -> str | None:
    """Get the socket address from environment variable or config."""
    # First check KITTY_LISTEN_ON environment variable
    listen_on = os.environ.get('KITTY_LISTEN_ON')
    if listen_on:
        return listen_on
    return None


def parse_address_spec(spec: str) -> tuple[socket.AddressFamily, str | tuple]:
    """Parse address specification like unix:/path or tcp:host:port."""
    protocol, rest = spec.split(':', 1)
    if protocol == 'unix':
        return socket.AF_UNIX, rest
    elif protocol == 'tcp':
        host, port = rest.rsplit(':', 1)
        return socket.AF_INET, (host, int(port))
    elif protocol == 'tcp6':
        # Handle IPv6 addresses with port
        if rest.startswith('['):
            # Format: [::1]:8080
            end_bracket = rest.rfind(']')
            if end_bracket > 0:
                host = rest[1:end_bracket]
                port = int(rest[end_bracket + 2 :])
                return socket.AF_INET6, (host, port)
        return socket.AF_INET6, (rest, 0)
    elif protocol == 'fd':
        raise ValueError('fd: protocol not supported in slim-kitten')
    else:
        raise ValueError(f'Unknown protocol: {protocol}')


def call_via_socket(cmd: str, payload: dict, timeout: float = 10.0) -> dict | None:
    """Send command via socket and return response."""
    listen_on = get_socket_address()
    if not listen_on:
        return None

    try:
        family, address = parse_address_spec(listen_on)
    except Exception as e:
        print(f'Failed to parse address: {e}', file=sys.stderr)
        return None

    kitty_cmd = {
        'cmd': cmd,
        'version': [0, 26, 0],
        'payload': payload,
    }

    sock = None
    try:
        sock = socket.socket(family, socket.SOCK_STREAM)
        sock.settimeout(timeout)
        sock.connect(address)

        # Send the command
        encoded = encode_send(kitty_cmd)
        sock.sendall(encoded)
        sock.shutdown(socket.SHUT_WR)

        # Read response
        dcs = re.compile(rb'\x1bP@kitty-cmd([^\x1b]+)\x1b\\')
        response_data = b''
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            response_data += chunk

        m = dcs.search(response_data)
        if m:
            return json.loads(m.group(1).decode('ascii'))
        return None

    except Exception as e:
        print(f'Socket error: {e}', file=sys.stderr)
        return None
    finally:
        if sock:
            try:
                sock.shutdown(socket.SHUT_RDWR)
            except Exception:
                pass
            sock.close()


def call_via_tty(cmd: str, payload: dict):
    """Send command via TTY escape codes."""
    kitty_cmd = {
        'cmd': cmd,
        'version': [0, 26, 0],
        'payload': payload,
        'no_response': True,
    }
    tty_string = f'\x1bP@kitty-cmd{json.dumps(kitty_cmd)}\x1b\\'
    write_tty(tty_string.encode())


def call_kitten(cmd: str, payload: dict):
    """Try socket first, fallback to TTY."""
    # Try socket first
    result = call_via_socket(cmd, payload)
    if result is not None:
        return result

    # Fallback to TTY
    call_via_tty(cmd, payload)


# 如何捕获kitten输出到tty的数据：
# script -f capture.log -c "kitten @ detach-window --target-tab 'hello'"


def argv_to_payload(argv: list[str]):
    payload = {}
    while len(argv) > 0:
        if argv[0].startswith('--'):
            payload[argv[0][2:].replace('-', '_')] = argv[1]
            argv = argv[2:]
        else:
            raise NotImplementedError
    return payload


def die(reason: str):
    sys.stderr.write(reason)
    sys.exit(1)


def main():
    argv = sys.argv[1:]
    if argv[0] == '@':
        argv = argv[1:]

    match argv[0]:
        case 'action':
            call_kitten('action', {'action': ' '.join(argv[1:])})
            pass
        case 'kitten':
            call_kitten('kitten', {'kitten': argv[1], 'args': argv[2:]})
        case 'detach-window':
            call_kitten('detach-window', argv_to_payload(argv[1:]))
        case _:
            payload = argv_to_payload(argv[1:])
            payload['output_format'] = 'json'
            result = call_kitten(argv[0], payload)
            if result:
                if not result['ok']:
                    die(result['error'])
                else:
                    print(json.dumps(result))


if __name__ == '__main__':
    main()

#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/bin:/run/current-system/sw/bin:/etc/profiles/per-user/$USER/bin:$PATH"

prog="${0##*/}"
kitten_script="scripts/coding_agent_status.py"

press_any_key() {
  if [[ -r /dev/tty ]]; then
    printf 'Press any key to exit...' >&2
    IFS= read -r -n 1 _ </dev/tty || true
    printf '\n' >&2
  fi
}

die() {
  printf '%s: %s\n' "$prog" "$*" >&2
  exit 1
}

usage() {
  cat >&2 <<EOF
Usage: $prog start|end|status [--agent NAME]

Commands:
  start       Record that the current coding agent started working
  end         Record that the current coding agent finished working
  status      Pick a coding agent window with fzf and focus it

Options:
  --agent NAME  Agent name to record (default: pi, or CODING_AGENT_NAME)
EOF
}

run_git_numstat() {
  git diff --numstat 2>/dev/null || true
}

sum_numstat() {
  awk '
    $1 ~ /^[0-9]+$/ { added += $1 }
    $2 ~ /^[0-9]+$/ { deleted += $2 }
    END { printf "%d\t%d", added, deleted }
  '
}

send_update() {
  local event="$1"
  local agent="$2"
  local cwd numstat added_deleted added deleted encoded

  cwd="${PWD:-$(pwd)}"
  numstat="$(run_git_numstat)"
  added_deleted="$(printf '%s\n' "$numstat" | sum_numstat)"
  IFS=$'\t' read -r added deleted <<<"$added_deleted"
  encoded="$(printf '%s' "$numstat" | base64 | tr -d '\n')"

  # Use --tty so kitty associates this request with the originating window,
  # which matters for SSH panes/windows where KITTY_WINDOW_ID is not exported.
  slim-kitten --tty @ kitten "$kitten_script" update \
    --event "$event" \
    --agent "$agent" \
    --cwd "$cwd" \
    --added "$added" \
    --deleted "$deleted" \
    --numstat-b64 "$encoded" >/dev/null 2>&1 || true
}

status_preview() {
  local window_id="$1"
  slim-kitten @ get-text --match "id:$window_id" --extent screen --ansi 2>/dev/null || echo "(unavailable)"
}

status_items() {
  slim-kitten @ kitten "$kitten_script" status 2>/dev/null || true
}

pick_status() {
  local selection window_id bash_path

  command -v fzf >/dev/null 2>&1 || die 'missing required command: fzf'

  export -f status_preview status_items
  bash_path="${BASH:-}"
  if [[ -z "$bash_path" ]]; then
    bash_path="$(command -v bash)" || die 'failed to find bash'
  fi

  SHELL="$bash_path" selection="$(status_items | fzf \
    --prompt='coding agents> ' \
    --header='enter: focus window' \
    --preview-window='right:70%,nowrap,border-left' \
    --ansi \
    --delimiter=$'\t' \
    --with-nth=2 \
    --nth=2 \
    --no-sort \
    --exact \
    --preview 'status_preview {1}')" || exit 0

  [[ -n "$selection" ]] || exit 0
  IFS=$'\t' read -r window_id _ <<<"$selection"
  [[ -n "$window_id" ]] || exit 0
  slim-kitten @ focus-window --match "id:$window_id" >/dev/null
}

main() {
  local command="" agent="${CODING_AGENT_NAME:-pi}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
    start|end|status)
      [[ -z "$command" ]] || die 'multiple commands specified'
      command="$1"
      shift
      ;;
    --agent)
      [[ $# -ge 2 ]] || die '--agent requires a value'
      agent="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      die "unknown argument: $1"
      ;;
    esac
  done

  [[ -n "$command" ]] || { usage; exit 2; }

  case "$command" in
  start|end) send_update "$command" "$agent" ;;
  status) pick_status ;;
  esac
}

main "$@"
